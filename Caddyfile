# Fallback Caddyfile — used when entrypoint.sh can't detect the public IP.
# Uses self-signed TLS on port 443.

:443 {
	tls internal

	handle /sse {
		reverse_proxy localhost:3000
	}

	handle /message {
		reverse_proxy localhost:3000
	}

	handle {
		@websocket {
			header Connection *Upgrade*
			header Upgrade websocket
		}
		reverse_proxy @websocket localhost:6080
		reverse_proxy localhost:6080
	}
}
