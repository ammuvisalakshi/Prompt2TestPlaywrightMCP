# This file is a TEMPLATE. entrypoint.sh generates the real Caddyfile
# at /app/Caddyfile.live with the actual sslip.io domain.
#
# Fallback: if entrypoint.sh can't detect the public IP, Caddy uses
# this file with self-signed TLS on port 443.

:443 {
	tls internal

	handle /sse {
		reverse_proxy localhost:3000
	}

	handle /message {
		reverse_proxy localhost:3000
	}

	handle {
		reverse_proxy localhost:6080
	}
}
